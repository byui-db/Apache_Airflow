# Environment variables for Apache Airflow setup
AIRFLOW_IMAGE_NAME=apache/airflow:3.1.3
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
_PIP_ADDITIONAL_REQUIREMENTS=-r /requirements.txt

# Fernet key for encrypting sensitive data in Airflow
FERNET_KEY=''

# Snowflake Credentials
# Account: use the ORG-ACCOUNT format shown in Snowsight → Account → Connect
#   Example: SFEDU02-RYB01601
#   (Snowsight may show a connections.toml snippet with authenticator="externalbrowser".
#    Ignore that line — this stack uses key-pair auth because DAGs run inside Docker
#    where no browser is available. Your instructor has already loaded your public key.)
SNOWFLAKE_USER=username
SNOWFLAKE_ACCOUNT=ORG-ACCOUNT
SNOWFLAKE_DATABASE=SNOWBEARAIR_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=ANIMAL_TASK_WH
SNOWFLAKE_ROLE=TRAINING_ROLE
# 📍 UPDATE THIS PATH — replace "username" with your actual username
#    Point this to your PRIVATE key file — NOT the .pub file (that one went to your instructor)
#    Mac:     /Users/johndoe/.ssh/dbt_key      (no extension on Mac)
#    Windows: C:/Users/johndoe/.ssh/dbt_key.p8
SNOWFLAKE_PRIVATE_KEY_PATH=/Users/username/.ssh/dbt_key

# MongoDB Credentials
MONGO_DB=
MONGO_COLLECTION=
MONGO_USER=student
MONGO_PASSWORD=
MONGO_HOST=
MONGO_PORT=

# SSH credentials (to get onto the server)
SSH_USER=student_ssh
SSH_PASSWORD=
SSH_HOST=
SSH_PORT=
SSH_KEY_PATH=/path/to/private/key  # or leave blank if using password auth

# uri = "mongodb://student:Password@localhost:27017/?authSource=dbname"

# SFTP credentials (to get onto the server)
SFTP_USER=student_sftp
SFTP_PASSWORD=
SFTP_HOST=
SFTP_PORT=
SFTP_DIR=